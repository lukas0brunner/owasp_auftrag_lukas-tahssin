# Copy this file to .env and replace the values before starting Docker.
# NEVER commit .env to version control.

# MariaDB root password (used by compose.db.yaml and compose.node.yaml)
MARIADB_ROOT_PASSWORD=change-me-in-production

# Secret used to sign Express sessions (min. 32 random characters)
SESSION_SECRET=change-me-to-a-random-32-char-string
